PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-secret

# Use either DATABASE_URL or the PG* fields.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kivo
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=kivo
# PGUSER=postgres
# PGPASSWORD=postgres
# PGSSL=false

# ─── Outgoing email (OTP codes) ───────────────────────────────────────────
# Option A: your own domain mail (e.g. DirectAdmin/cPanel/Zoho).
# Use EITHER naming style below — both are read automatically:
#
#   SMTP_HOST=mail.yourdomain.com
#   SMTP_PORT=587
#   SMTP_USER=noreply@yourdomain.com
#   SMTP_PASS=your-mailbox-password
#
# ...or paste Laravel-style vars directly, no renaming needed:
#   MAIL_MAILER=smtp
#   MAIL_SCHEME=smtps
#   MAIL_HOST=mail.yourdomain.com
#   MAIL_PORT=465
#   MAIL_USERNAME=noreply@yourdomain.com
#   MAIL_PASSWORD=your-mailbox-password
#   MAIL_FROM_ADDRESS=noreply@yourdomain.com
#   MAIL_FROM_NAME=Kivo
#
EMAIL_FROM=Kivo <noreply@yourdomain.com>

# Option B: Resend (used only if no SMTP config above is set)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Kivo <onboarding@resend.dev>

